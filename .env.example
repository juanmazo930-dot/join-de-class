# Copia este archivo a .env y completa con los datos de tu proyecto Firebase
# (Firebase console -> Project settings -> General -> Tus apps -> Config).
# El sitio funciona sin esto (sin login/gating), pero para activar
# autenticacion + newsletter en Firestore necesitas rellenarlo.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
